# 通义千问配置（Key 在 https://bailian.console.aliyun.com/ 获取）
OPENAI_API_KEY=你的API_KEY
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen-plus

# Day24 — 环境与日志
APP_ENV=dev
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_CONSOLE=true

# 本地 Ollama 配置（Day04 默认）
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# MODEL_NAME=qwen3:4b
# PROVIDER=ollama

# 上传与解析目录（Day08/09）
UPLOAD_DIR=uploads
PARSED_DIR=data/parsed

# Chunk 切分（Day10）
CHUNKS_DIR=data/chunks
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Embedding 向量化（Day11）
VECTORS_DIR=data/vectors
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSION=512

# 云端 Embedding 示例（取消注释并配置 Key）
# EMBEDDING_PROVIDER=dashscope
# EMBEDDING_MODEL=text-embedding-v3
# OPENAI_API_KEY=你的API_KEY
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Chroma 向量库（Day12）
# 本地开发默认 embedded；Docker Compose 使用 server 模式（见 docker-compose.yml）
CHROMA_MODE=embedded
CHROMA_DIR=data/chroma
CHROMA_HOST=localhost
CHROMA_PORT=8000
CHROMA_COLLECTION=knowledge
SEARCH_TOP_K=5

# Day22 — Docker Compose / Redis（可选）
# REDIS_URL=redis://redis:6379/0
#
# Compose 双模式：
#   docker compose up              → 通义等云端 LLM（读下方配置）
#   docker compose --profile local-llm up  → 容器内 Ollama（自动覆盖 LLM 连接）

# RAG 问答（Day13）
# RAG_SYSTEM_PROMPT=你是一名企业知识库助手……

# Agent 问答（Day15）
# AGENT_ANSWER_PROMPT=你是企业知识库助手……

# Agent 记忆（Day17）
MEMORY_DIR=data/conversations
MEMORY_MAX_TURNS=10

# Day18/19 — MCP Client（默认 Filesystem Server）
MCP_ENABLED=false
MCP_SERVER_COMMAND=npx
# 沙箱根目录（绝对路径）；未设置 MCP_SERVER_ARGS 时由代码自动拼接
MCP_FILESYSTEM_ROOT=E:/2026/learn/ai-project-assistant
# MCP_SERVER_ARGS=-y,@modelcontextprotocol/server-filesystem,E:/2026/learn/ai-project-assistant

# Day21_2 — 天气 / 新闻 Tool
WEATHER_ENABLED=true
NEWS_ENABLED=true
NEWS_MAX_ITEMS=5
TOOL_HTTP_TIMEOUT=10
# 逗号分隔 RSS 地址，可换成你信任的源
NEWS_RSS_FEEDS=https://feeds.bbci.co.uk/news/world/rss.xml,https://www.chinanews.com.cn/rss/scroll-news.xml

# 体育 Tool（TheSportsDB，默认测试 Key 为 3）
SPORTS_ENABLED=true
SPORTSDB_API_KEY=3
SPORTS_MAX_ITEMS=5
SPORTS_DEFAULT_LEAGUE_ID=4328
SPORTS_RSS_FEEDS=https://feeds.bbci.co.uk/sport/rss.xml
