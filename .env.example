# 通义千问配置（Key 在 https://bailian.console.aliyun.com/ 获取）
OPENAI_API_KEY=你的API_KEY
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
MODEL_NAME=qwen-plus

# 本地 Ollama 配置（Day04 默认）
# OPENAI_API_KEY=ollama
# OPENAI_BASE_URL=http://127.0.0.1:11434/v1
# MODEL_NAME=qwen3:4b
# PROVIDER=ollama

# 上传与解析目录（Day08/09）
UPLOAD_DIR=uploads
PARSED_DIR=data/parsed

# Chunk 切分（Day10）
CHUNKS_DIR=data/chunks
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Embedding 向量化（Day11）
VECTORS_DIR=data/vectors
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
EMBEDDING_DIMENSION=512

# 云端 Embedding 示例（取消注释并配置 Key）
# EMBEDDING_PROVIDER=dashscope
# EMBEDDING_MODEL=text-embedding-v3
# OPENAI_API_KEY=你的API_KEY
# OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Chroma 向量库（Day12）
CHROMA_DIR=data/chroma
CHROMA_COLLECTION=knowledge
SEARCH_TOP_K=5

# RAG 问答（Day13）
# RAG_SYSTEM_PROMPT=你是一名企业知识库助手……

# Agent 问答（Day15）
# AGENT_ANSWER_PROMPT=你是企业知识库助手……

# Agent 记忆（Day17）
MEMORY_DIR=data/conversations
MEMORY_MAX_TURNS=10

# Day18 — MCP Client
MCP_ENABLED=false
MCP_SERVER_COMMAND=npx
MCP_SERVER_ARGS=-y,@modelcontextprotocol/server-everything
